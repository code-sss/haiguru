DATABASE_URL=postgresql://<db_user>:<db_password>@<db_host>:<db_port>/<db_name>
EMBED_MODEL=BAAI/bge-m3
EMBED_DIM=1024
EMBED_DEVICE=cuda
# Optional: local model cache path (e.g. C:/models)
MODEL_PATH=./models
# Ollama model used for RAG answer synthesis
RAG_MODEL=qwen3.5:9b
# Ollama model used for exercise transform
TRANSFORM_MODEL=qwen3.5:9b
# KV cache context window — reduce if Ollama reports out-of-memory
LLM_CONTEXT_WINDOW=4096
# Ollama request timeout in seconds
LLM_REQUEST_TIMEOUT=360

# External LLM provider API keys (only needed when using that provider)
# Use model prefix: openai://gpt-4o, anthropic://claude-3-5-sonnet-20241022, together://<model>
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
TOGETHER_API_KEY=
